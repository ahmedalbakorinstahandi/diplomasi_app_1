# Moyasar — المفتاح العام pk_* فقط (للموبايل). مفاتيح sk_* تبقى في الباكند فقط.
# عند تعبيرها هنا، تُفضَّل على publishable_key القادم من الـ API عند تطابق الوضع من الإعدادات.
MOYASAR_TEST_PUBLIC_KEY=
MOYASAR_LIVE_PUBLIC_KEY=
# عند فشل طلب الـ API: test | live
MOYASAR_MODE=test
# يجب أن يطابق الباكند MOYASAR_CURRENCY (ISO 4217)
MOYASAR_CURRENCY=USD
